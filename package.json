{
  "name": "skillfight",
  "version": "0.0.0",
  "private": true,
  "description": "An arena where Claude skills fight. Analyze a folder of skills, find overlaps, decide winner/merge/coexist.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "analyze": "pnpm --filter @skillfight/core analyze",
    "tui": "pnpm --filter @skillfight/tui start",
    "tui:demo": "pnpm --filter @skillfight/tui demo",
    "web": "pnpm --filter @skillfight/web dev"
  }
}
